{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ADMIN_API_TOKEN",
    "ADMIN_LOGIN_PASSWORD",
    "ADMIN_SESSION_SECRET",
    "AMAP_KEY",
    "CORS_ALLOWED_ORIGINS",
    "CRON_SECRET",
    "DATABASE_URL",
    "DEEPSEEK_API_KEY",
    "DEEPSEEK_MODEL",
    "JWT_SECRET",
    "NEXT_PUBLIC_AMAP_KEY",
    "NEXT_PUBLIC_HOME_HERO_VIDEO_URL",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_WEB_API_BASE",
    "QWEATHER_API_HOST",
    "QWEATHER_API_KEY",
    "QWEATHER_LOCATION_ID",
    "REDIS_URL",
    "SENSOR_API_KEY",
    "SMS_API_KEY",
    "SMS_TEMPLATE_ID",
    "WEB_API_BASE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
