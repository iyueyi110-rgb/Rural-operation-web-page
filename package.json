{
  "name": "zouma-village-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --check .",
    "simulation:run": "pnpm --filter @zouma/simulation cli run",
    "simulation:regression": "pnpm --filter @zouma/simulation cli regression",
    "simulation:compare": "pnpm --filter @zouma/simulation cli compare",
    "simulation:export": "pnpm --filter @zouma/simulation cli export"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  }
}
